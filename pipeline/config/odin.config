/*
 * Nextflow config for ODIN — pipeline profiles for Docker-outside-of-Docker (DooD) execution.
 */

// ── Corporate CA certificate ──────────────────────────────────────────────────
// If your network uses an SSL-intercepting proxy, point ODIN_CA_CERT at your
// organisation's CA cert (PEM format).  Two layers ensure TLS verification works
// regardless of whether a pipeline supports beforeScript:
//
//   Layer 1 — docker.runOptions: mounts the cert into every container and sets
//     CURL_CA_BUNDLE / REQUESTS_CA_BUNDLE / SSL_CERT_FILE / NODE_EXTRA_CA_CERTS.
//
//   Layer 2 — process.beforeScript: builds a combined bundle (system CAs + your
//     CA) so direct HTTPS connections that bypass the proxy also succeed.
//
// If ODIN_CA_CERT is unset, a cert is auto-discovered from $ODIN_PIPELINE_ROOT/ca/
// (any *.cer, *.crt, or *.pem file found there).
def _ca = System.getenv('ODIN_CA_CERT') ?: ''
if (!_ca) {
    def _root = System.getenv('ODIN_PIPELINE_ROOT') ?: ''
    if (_root) {
        def _cert = new File("${_root}/ca").listFiles()
            ?.find { it.isFile() && it.name =~ /\.(cer|crt|pem)$/ }
        if (_cert) _ca = _cert.absolutePath
    }
}
def _caMount   = _ca ? " -v ${_ca}:/odin-ca.crt:ro -v /app/ca/odin-wgetrc:/tmp/odin-wgetrc:ro" : ''
def _caEnvOpts = _ca ? " -e WGETRC=/tmp/odin-wgetrc -e CURL_CA_BUNDLE=/odin-ca.crt -e REQUESTS_CA_BUNDLE=/odin-ca.crt -e SSL_CERT_FILE=/odin-ca.crt -e NODE_EXTRA_CA_CERTS=/odin-ca.crt" : ''
def _beforeScript = _ca ? '''if [ -f /odin-ca.crt ]; then
  cat /etc/ssl/certs/ca-certificates.crt /odin-ca.crt > /tmp/odin-ca-bundle.pem 2>/dev/null || cp /odin-ca.crt /tmp/odin-ca-bundle.pem
  printf 'ca-certificate = /tmp/odin-ca-bundle.pem\n' > /tmp/.odin-wgetrc
  export WGETRC=/tmp/.odin-wgetrc
  export SSL_CERT_FILE=/tmp/odin-ca-bundle.pem
  export REQUESTS_CA_BUNDLE=/tmp/odin-ca-bundle.pem
  export CURL_CA_BUNDLE=/tmp/odin-ca-bundle.pem
  export NODE_EXTRA_CA_CERTS=/tmp/odin-ca-bundle.pem
fi''' : ''
// ─────────────────────────────────────────────────────────────────────────────

def odinTmpDir = System.getenv('ODIN_TMP_DIR') ?: ''
def odinTmpRunOptions = odinTmpDir ? " -v ${odinTmpDir}:${odinTmpDir}" : ''

// NXF_ASSETS must be a host-accessible path so task containers spawned via DooD
// can mount it.  Set to $ODIN_PIPELINE_ROOT/nf-assets via docker-compose environment.
def _nfAssets = System.getenv('NXF_ASSETS') ?: ''
def _nfAssetsMount = _nfAssets ? " -v ${_nfAssets}:${_nfAssets}:ro" : ''

profiles {

    odin {
        docker.enabled          = true
        conda.enabled           = false
        singularity.enabled     = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
        apptainer.enabled       = false
        docker.runOptions       = '-u $(id -u):$(id -g) --group-add 100' + _nfAssetsMount + _caMount + _caEnvOpts + odinTmpRunOptions
        executor.name           = 'local'
        executor.cpus           = 4
        executor.memory         = 16.GB
        process {
            beforeScript = _beforeScript
            resourceLimits = [
                memory: 16.GB,
                cpus  : 4,
            ]
            // multiqc_config.yml is staged from inside the ODIN container at a path that
            // does not exist on the host — symlinks break.  Copy for MULTIQC only; all
            // other processes keep symlinks to avoid duplicating large database files.
            withName: '.*MULTIQC' {
                stageInMode = 'copy'
            }
            withName: '.*FASTQC' {
                cpus = 4
                memory = 16.GB
            }
        }
    }

    // Like 'odin' but without resourceLimits.  Use for pipelines that may exceed
    // 16 GB or that do not declare 'time' directives (making a time cap meaningless).
    odin_epi2me {
        docker.enabled          = true
        conda.enabled           = false
        singularity.enabled     = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
        apptainer.enabled       = false
        docker.runOptions       = '-u $(id -u):$(id -g) --group-add 100' + _nfAssetsMount + _caMount + _caEnvOpts + odinTmpRunOptions
        executor.name           = 'local'
        process {
            beforeScript = _beforeScript
            withName: '.*MULTIQC' {
                stageInMode = 'copy'
            }
        }
    }

    odin_big {
        docker.enabled          = true
        conda.enabled           = false
        singularity.enabled     = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
        apptainer.enabled       = false
        docker.runOptions       = '-u $(id -u):$(id -g) --group-add 100' + _nfAssetsMount + _caMount + _caEnvOpts + odinTmpRunOptions
        executor.name           = 'local'
        executor.cpus           = 16
        executor.memory         = 31.GB
        process {
            beforeScript = _beforeScript
            resourceLimits = [
                memory: 31.GB,
                cpus  : 16,
            ]
            withName: '.*MULTIQC' {
                stageInMode = 'copy'
            }
            withName: '.*FASTQC' {
                cpus = 4
                memory = 16.GB
            }
        }
    }

}
